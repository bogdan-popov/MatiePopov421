<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MatiePopov421.LoginWindow"
        Title="Матье — Вход"
        Width="1024" Height="680"
        CanResize="False"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Border BorderBrush="#7C3AED" BorderThickness="2">
        <Grid RowDefinitions="44,*">

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#7C3AED" x:Name="titleBar">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Image Grid.Column="0" x:Name="titleLogoImage"
                           Width="28" Height="28" Margin="10,0,8,0" Stretch="Uniform"/>
                    <TextBlock Grid.Column="1" Text="Матье — Студия костюмов"
                               Foreground="White" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="2" x:Name="closeBtnLogin"
                            Content="✕" Width="44" Height="44"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0" FontSize="14"/>
                </Grid>
            </Border>

            <!-- Two-column layout -->
            <Grid Grid.Row="1" ColumnDefinitions="*,420">

                <!-- Left: branding panel -->
                <Border Grid.Column="0" Background="#8B5CF6">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Spacing="20" Margin="40,0">
                        <Border Width="110" Height="110" CornerRadius="55"
                                Background="#A78BFA" HorizontalAlignment="Center">
                            <Image x:Name="logoImage" Stretch="Uniform" Margin="14"/>
                        </Border>
                        <TextBlock Text="Матье" FontSize="36" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Студия авторских костюмов"
                                   FontSize="16" Foreground="#EDE9FE"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                        <Border Background="#7C3AED" CornerRadius="8" Padding="20,14"
                                Margin="0,10,0,0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="• Аниме-образы" Foreground="#EDE9FE" FontSize="13"/>
                                <TextBlock Text="• Новогодние костюмы" Foreground="#EDE9FE" FontSize="13"/>
                                <TextBlock Text="• Хэллоуинские наряды" Foreground="#EDE9FE" FontSize="13"/>
                                <TextBlock Text="• Киберпанк и нуар" Foreground="#EDE9FE" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Right: form panel -->
                <Border Grid.Column="1" Background="White" Padding="40,30">
                    <Grid RowDefinitions="Auto,*">

                        <!-- Tab switcher -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,24">
                            <Button Grid.Column="0" x:Name="showLoginBtn"
                                    Content="Вход" Height="40" Width="170"
                                    Background="#7C3AED" Foreground="White"
                                    BorderThickness="0" CornerRadius="6,0,0,6"
                                    FontWeight="SemiBold" FontSize="14"/>
                            <Button Grid.Column="1" x:Name="showRegisterBtn"
                                    Content="Регистрация" Height="40" Width="170"
                                    Background="#EDE9FE" Foreground="#5B21B6"
                                    BorderThickness="0" CornerRadius="0,6,6,0"
                                    FontSize="14"/>
                        </Grid>

                        <!-- Login form -->
                        <StackPanel Grid.Row="1" x:Name="loginPanel" Spacing="14">
                            <TextBlock Text="Добро пожаловать!" FontSize="22"
                                       FontWeight="Bold" Foreground="#4C1D95"
                                       Margin="0,0,0,6"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Логин" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="loginUsernameBox" Height="40"
                                         Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Пароль" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="loginPasswordBox" PasswordChar="●"
                                         Height="40" Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <Button x:Name="loginBtn" Content="Войти"
                                    Height="46" Margin="0,10,0,0"
                                    HorizontalAlignment="Stretch"
                                    Background="#7C3AED" Foreground="White"
                                    BorderThickness="0" CornerRadius="8"
                                    FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock FontSize="11" Foreground="#9CA3AF"
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,8,0,0">
                            </TextBlock>
                        </StackPanel>

                        <!-- Register form -->
                        <StackPanel Grid.Row="1" x:Name="registerPanel"
                                    IsVisible="False" Spacing="10">
                            <TextBlock Text="Создать аккаунт" FontSize="22"
                                       FontWeight="Bold" Foreground="#4C1D95"
                                       Margin="0,0,0,4"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Логин" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="regUsernameBox" Height="38"
                                         Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Полное имя" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="regFullNameBox" Height="38"
                                         Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Пароль" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="regPasswordBox" PasswordChar="●"
                                         Height="38" Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Повторите пароль" FontSize="12"
                                           Foreground="#6D28D9" FontWeight="SemiBold"/>
                                <TextBox x:Name="regConfirmBox" PasswordChar="●"
                                         Height="38" Padding="12,0" CornerRadius="6"/>
                            </StackPanel>
                            <Button x:Name="registerBtn"
                                    Content="Зарегистрироваться"
                                    Height="44" Margin="0,6,0,0"
                                    HorizontalAlignment="Stretch"
                                    Background="#7C3AED" Foreground="White"
                                    BorderThickness="0" CornerRadius="8"
                                    FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>

                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>
</Window>
